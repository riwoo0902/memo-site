<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>웹 메모장</title>
    <style>
        body {
            margin: 0;
            background: #f4f4f4;
            font-family: Arial, sans-serif;
        }

        header {
            background: #333;
            color: white;
            padding: 10px;
            text-align: center;
            font-size: 18px;
        }

        textarea {
            width: 100%;
            height: calc(100vh - 50px);
            border: none;
            resize: none;
            padding: 15px;
            font-size: 16px;
            outline: none;
            box-sizing: border-box;
        }
    </style>
</head>
<body>

<header>📒 웹 메모장</header>
<textarea id="memo" placeholder="여기에 자유롭게 입력하세요..."></textarea>

<script>
    const textarea = document.getElementById("memo");

    // 저장된 내용 불러오기
    textarea.value = localStorage.getItem("memoData") || "";

    // 입력할 때마다 자동 저장
    textarea.addEventListener("input", () => {
        localStorage.setItem("memoData", textarea.value);
    });
</script>

</body>
</html>
